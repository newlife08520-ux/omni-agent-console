{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "dev:worker": "cross-env NODE_ENV=development tsx server/workers/ai-reply.worker.ts",
    "build": "npm run check:server && tsx script/build.ts",
    "preview": "vite preview --config vite.config.ts",
    "start": "cross-env NODE_ENV=production node dist/index.cjs",
    "start:worker": "cross-env NODE_ENV=production node dist/workers/ai-reply.worker.cjs",
    "check": "tsc",
    "check:server": "tsc -p tsconfig.server.json",
    "check:all": "tsc",
    "verify:server": "npm run check:server && npm run build",
    "verify:full": "npm run check:all && npm run build",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true});require('fs').rmSync('node_modules/.cache',{recursive:true,force:true})\"",
    "verify": "npm run verify:server",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync:prompt": "tsx server/scripts/sync-global-prompt.ts",
    "pilot:precheck": "tsx server/scripts/pilot-precheck.ts",
    "db:push": "drizzle-kit push",
    "audit:superlanding": "tsx server/scripts/audit-superlanding-order-payload.ts",
    "audit:shopline": "tsx server/scripts/audit-shopline-order-payload.ts",
    "audit:payloads": "npm run audit:superlanding && npm run audit:shopline",
    "sync:orders": "tsx server/scripts/sync-orders-normalized.ts",
    "diagnose:review-db": "tsx server/scripts/diagnose-review-bundle-db.ts",
    "verify:r1": "npm run check:server && tsx server/r1-verify.ts",
    "verify:phase1-ops": "tsx server/phase1-agent-ops-verify.ts",
    "verify:phase15": "tsx server/phase15-verify.ts",
    "verify:phase16": "tsx server/phase16-pilot-proof-harness.ts",
    "bundle:impl-v2": "node scripts/build-implementation-bundle-v2.mjs",
    "bundle:impl-v3": "node scripts/build-implementation-bundle-v3.mjs",
    "bundle:impl-v4": "node scripts/build-implementation-bundle-v4.mjs",
    "zip:evidence": "node scripts/zip-functional-evidence.mjs",
    "zip:pilot-evidence": "node scripts/zip-pilot-evidence.mjs"
  },
