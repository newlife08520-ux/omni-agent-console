# 正式部署時請複製為 .env 並填入實際值，勿提交 .env
# 說明見 docs/DEPLOYMENT_READINESS_AND_PLAN.md

NODE_ENV=production
PORT=5001

# 必填（production 未設會拒絕啟動）
SESSION_SECRET=

# 必填（production）：主站與 Worker 都需設。Session 持久化與 AI 回覆佇列。例：redis://default:xxx@xxx.railway.app:port
REDIS_URL=

# 主站與 Worker 都必填，且值必須一致（Worker 打 /internal/run-ai-reply 時帶此 secret）
INTERNAL_API_SECRET=

# Worker 打回主站 internal API 的網址。本機可用 http://localhost:5001 或實際主站 port；Railway 若 Worker 為獨立 Service 請填主站對外網址
INTERNAL_API_URL=

# 資料目錄：SQLite 與 uploads 根目錄。production 建議 /data（對應 Railway Volume）；dev 不設則用專案目錄
# DATA_DIR=/data

# 對外網域（不含 https://），用於 webhook URL、SSE、圖片連結等
APP_DOMAIN=

# Meta Webhook 驗證用（與 FB 開發者後台設定一致）
FB_VERIFY_TOKEN=

# 選填：覆寫後台預設的 OpenAI 模型（未設時以後端 fallback 為主）
# OPENAI_MODEL=gpt-4o-mini

# 注意：test_mode 為 DB 設定（settings 表），非 .env 變數
