# 正式部署時請複製為 .env 並填入實際值，勿提交 .env
# 說明見 docs/DEPLOYMENT_READINESS_AND_PLAN.md

NODE_ENV=production
PORT=5001

# 必填（production 未設會拒絕啟動）
SESSION_SECRET=

# 必填（production）：Session 持久化，多人不互踢。例：redis://default:xxx@xxx.railway.app:port
REDIS_URL=

# 資料目錄：SQLite 與 uploads 根目錄。production 建議 /data（對應 Railway Volume）；dev 不設則用專案目錄
# DATA_DIR=/data

# 對外網域（不含 https://），用於 webhook URL、SSE、圖片連結等
APP_DOMAIN=

# Meta Webhook 驗證用（與 FB 開發者後台設定一致）
FB_VERIFY_TOKEN=

# 選填：覆寫後台預設的 OpenAI 模型
# OPENAI_MODEL=gpt-4o-mini
